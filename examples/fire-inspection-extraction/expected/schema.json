{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "panel_model": { "type": "string" },
    "device_status": { "type": "string" },
    "pass_fail_result": { "type": "string", "enum": ["pass", "fail", "inconclusive"] },
    "notes": { "type": "string" },
    "devices": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "device_id": { "type": "string" },
          "model_family": { "type": "string" }
        },
        "required": ["device_id", "model_family"]
      }
    }
  },
  "required": ["panel_model", "device_status"],
  "additionalProperties": false
}
